{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "financial-analyst",
  "version": "0.1.0",
  "identifier": "com.jesson-hh.financial-analyst",
  "build": {
    "frontendDist": "../../../stocks/fa_ui_ready",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../../../stocks/fa_ui_ready && python -m http.server 5173",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "觀瀾 — financial-analyst",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:9999 ws://127.0.0.1:9999 https://unpkg.com 'unsafe-inline' 'unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "appimage", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [
      "binaries/financial-analyst"
    ],
    "copyright": "Apache 2.0",
    "category": "Finance",
    "shortDescription": "A-share single-stock 14-agent deep-dive research workstation",
    "longDescription": "觀瀾 (GuanLan) — desktop UI for financial-analyst. 14-agent A-share research swarm with 4 trust tiers, FTS5 memory retrieval, dream-loop introspection, and direct-connect data pipeline (no Tushare token required)."
  }
}
