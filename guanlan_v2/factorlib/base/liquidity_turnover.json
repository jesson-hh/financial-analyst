[
  {
    "name": "lib_turnover_cv20",
    "family": "library",
    "expr": "stddev(turnover_rate,20)/(ts_mean(turnover_rate,20)+1e-8)",
    "description": "20日换手率变异系数(换手稳定性,越高越躁动)。",
    "source": "stocks/results/factor_mining/rolling_top30_factors.txt#turnover_cv20",
    "qlib_src": "Std($turnover_rate,20)/(Mean($turnover_rate,20)+1e-8)"
  },
  {
    "name": "lib_turnover_jump_ratio",
    "family": "library",
    "expr": "turnover_rate/(ts_mean(turnover_rate,20)+1e-8)",
    "description": "换手跳升比:当日换手 / 20日均换手。",
    "source": "stocks/results/factor_mining/rolling_top30_factors.txt#turnover_jump_ratio",
    "qlib_src": "$turnover_rate/(Mean($turnover_rate,20)+1e-8)"
  },
  {
    "name": "lib_amount_surge_3d_20d",
    "family": "library",
    "expr": "ts_mean(amount,3)/(ts_mean(amount,20)+1e-8)",
    "description": "成交额放量:3日均额 / 20日均额。",
    "source": "stocks/results/factor_mining/rolling_top30_factors.txt#amount_surge_3d_20d",
    "qlib_src": "Mean($amount,3)/(Mean($amount,20)+1e-8)"
  },
  {
    "name": "lib_amount_share_5d_60d",
    "family": "library",
    "expr": "ts_sum(amount,5)/(ts_sum(amount,60)+1e-8)",
