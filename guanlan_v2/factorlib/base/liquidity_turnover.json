    "source": "stocks/results/factor_mining/rolling_top30_factors.txt#amount_share_5d_60d",
    "qlib_src": "Sum($amount,5)/(Sum($amount,60)+1e-8)"
  },
  {
    "name": "lib_amt_concentration_5v20",
    "family": "library",
    "expr": "ts_sum(amount,5)/(ts_sum(amount,20)+1e-8)",
    "description": "成交额集中度:近5日额 / 近20日额。",
    "source": "stocks/results/factor_mining/rolling_top30_factors.txt#amt_concentration_5v20",
