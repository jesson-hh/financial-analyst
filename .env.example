# guanlan-v2 运行所需环境变量 —— 复制本文件为 .env (gitignore 之), 或在系统环境设置。
# 真实密钥不要写进仓库; 引擎运行时从 os.environ 读取。

# ── LLM key ───────────────────────────────────────────────
# config/llm.yaml 默认 provider = deepseek (api_key_env: DEEPSEEK_API_KEY)。
# 不设则 /models 不列 deepseek, /run 答案合成会 401。
DEEPSEEK_API_KEY=

# 可选: config/llm.yaml 里休眠的 provider, 设了对应 key 才会出现在 /models。
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── 数据路径 (默认经 config/loaders.yaml → G:/stocks; 一般无需设) ──
# 见 docs/data_contract.md。覆盖时:
# FA_PARQUET_ROOT=G:/stocks/stock_data/parquet
# FA_NEWS_DATA_ROOT=G:/stocks/news_data
# FA_QLIB_URI=G:/stocks/stock_data/cn_data

# ── 引擎源 / 配置覆盖 (默认已指向仓库内 engine/ 与 config/, 一般无需设) ──
# GUANLAN_FA_SRC=G:/fa-watch-wt/src     # 指回上游引擎做 A/B
# FA_CONFIG_DIR=G:/guanlan-v2/config    # 显式锁定配置目录

# ── 服务监听 (默认 127.0.0.1:9999) ──
# GUANLAN_HOST=127.0.0.1
# GUANLAN_PORT=9999
